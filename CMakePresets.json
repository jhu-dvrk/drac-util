{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 22,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-msvc-x64",
      "displayName": "Windows MSVC x64",
      "description": "Visual Studio 2022 x64 with FireWire disabled for the Windows Ethernet-only workflow.",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build/windows-msvc-x64",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "Amp1394_HAS_RAW1394": "OFF",
        "Amp1394_HAS_PCAP": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-debug",
      "configurePreset": "windows-msvc-x64",
      "configuration": "Debug"
    },
    {
      "name": "windows-release",
      "configurePreset": "windows-msvc-x64",
      "configuration": "Release"
    }
  ]
}

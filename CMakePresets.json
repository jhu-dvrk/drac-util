{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 22,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "linux-gcc",
      "displayName": "Linux GCC",
      "description": "Linux build with raw1394 enabled by default.",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/linux-gcc",
      "cacheVariables": {
        "Amp1394_HAS_RAW1394": "ON",
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "windows-msvc-x64",
      "displayName": "Windows MSVC x64",
      "description": "Visual Studio 2022 x64 with FireWire disabled for the Windows Ethernet-only workflow.",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build/windows-msvc-x64",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "Amp1394_HAS_RAW1394": "OFF",
        "Amp1394_HAS_PCAP": "OFF",
        "VCPKG_MANIFEST_MODE": "OFF"
      }
    },
    {
      "name": "manual-classic",
      "displayName": "Manual Setup (VCPKG classic), Visual Studio 2022",
      "generator": "Visual Studio 17 2022",
      "cacheVariables": {
          "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
          "VCPKG_MANIFEST_MODE": "OFF"
      }
    },
    {
      "name": "manual-manifest",
      "displayName": "Manual Setup (VCPKG manifest), Visual Studio 2022",
      "generator": "Visual Studio 17 2022",
      "cacheVariables": {
          "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "linux-release",
      "configurePreset": "linux-gcc"
    },
    {
      "name": "windows-debug",
      "configurePreset": "windows-msvc-x64",
      "configuration": "Debug"
    },
    {
      "name": "windows-release",
      "configurePreset": "windows-msvc-x64",
      "configuration": "Release"
    }
  ]
}
